# ── Server ────────────────────────────────────────────────
PORT=3000
# Publicly reachable https URL (ngrok/domain) — webhooks & the media stream use it
PUBLIC_BASE_URL=https://your-domain.com

# ── Database (PostgreSQL only) ────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/leads?schema=public"

# ── Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# GEMINI_VOICE=Charon
# GEMINI_TEXT_MODEL=gemini-2.0-flash

# ── Call provider (vobiz is the default; twilio kept for future use) ──
CALL_PROVIDER=vobiz

# ── Vobiz ─────────────────────────────────────────────────
VOBIZ_AUTH_ID=your-vobiz-auth-id
VOBIZ_AUTH_TOKEN=your-vobiz-auth-token
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX

# ── Twilio (optional — only needed if CALL_PROVIDER=twilio) ──
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Dialer (defaults shown) ───────────────────────────────
# DIALER_ENABLED=true
# DIALER_INTERVAL_SECONDS=30
# DIALER_BATCH_SIZE=5
# MAX_CALL_RETRIES=3
# RETRY_WAIT_SECONDS=300
# CALL_WINDOW_START=10:00
# CALL_WINDOW_END=19:00

# Default country code used when a phone number is given without a "+"
DEFAULT_COUNTRY_CODE=+91
