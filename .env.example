PORT=3000

# Postgres (used by Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/voice_calls?schema=public"

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Publicly reachable base URL for this app (Twilio must be able to reach it).
# Use an ngrok URL in local dev, e.g. https://abcd1234.ngrok.io
PUBLIC_BASE_URL=https://your-public-domain.com

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=calls

# Default country code used when a phone number is given without a "+"
DEFAULT_COUNTRY_CODE=+91
